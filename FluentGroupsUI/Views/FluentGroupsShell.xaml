<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FluentGroupsUI.Views.FluentGroupsShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12,8,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Style="{ThemeResource SubtleButtonStyle}"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <TextBlock x:Name="PageTitleText"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Text="Home"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>

        <Frame x:Name="PageFrame" Grid.Row="1">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition />
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</UserControl>

