<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluentGroupsUI.Views.HomeShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Margin="0,6,0,12"
                 PlaceholderText="Search groups"
                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        
        <ListView x:Name="NotesListView"
              Grid.Row="1"
              ItemsSource="{Binding Notes}"
              SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
              IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" RowSpacing="4">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Edit" CommandParameter="{Binding}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE70F;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Delete" CommandParameter="{Binding}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{x:Bind}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Text="{x:Bind}" Opacity="0.75" TextTrimming="CharacterEllipsis" MaxLines="2" />
                        <TextBlock Grid.Row="2" Text="{x:Bind}" FontSize="12" Opacity="0.6" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <Grid Grid.Row="2"
              Margin="0,12,0,0"
              ColumnSpacing="12"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                    <TextBlock Text="New group" />
                </StackPanel>
            </Button>
            
            <Button Grid.Column="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="16" />
                    <TextBlock Text="Reload" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Click="SettingsButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                    <TextBlock Text="Settings" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>

